{
  "name": "omni-commander-mcp",
  "version": "0.2.0-bootstrap",
  "description": "Cross-platform local and remote MCP agent for terminal, OS automation, and computer use.",
  "type": "module",
  "bin": { "omni-commander": "dist/index.js" },
  "engines": { "node": ">=20" },
  "scripts": {
    "materialize": "node scripts/materialize-source.mjs",
    "bootstrap": "node scripts/materialize-source.mjs && npm install && npm run check && npm run build",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^5.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
