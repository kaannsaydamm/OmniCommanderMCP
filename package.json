{
  "name": "omni-commander-mcp",
  "version": "0.2.0",
  "description": "A local-first, cross-platform MCP server for full desktop, filesystem, terminal, process, network and system control.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omni-commander": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "deploy",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    ".env.example",
    "mcp.example.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test",
    "start:http": "node dist/index.js --http",
    "dev:http": "tsx src/index.ts --http"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "desktop-automation",
    "filesystem",
    "terminal",
    "process-management",
    "ai-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^5.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
