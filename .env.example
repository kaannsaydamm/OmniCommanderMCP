# safe | full
OMNI_PROFILE=safe

# Optional path-delimited roots for safe mode.
# Windows: C:\Users\Kaan\Projects;D:\Data
# Linux/macOS: /home/kaan/projects:/srv/data
OMNI_ALLOWED_ROOTS=
OMNI_CONFIG_PATH=
OMNI_AUDIT_ENABLED=true

# Optional PowerShell executable override, for example pwsh.exe.
OMNI_POWERSHELL=

# Optional authenticated Streamable HTTP mode.
OMNI_HTTP_HOST=127.0.0.1
OMNI_HTTP_PORT=8787
OMNI_HTTP_TOKEN=
OMNI_HTTP_ALLOWED_HOSTS=

# Used only by the separate official OpenAI tunnel-client process.
CONTROL_PLANE_API_KEY=
OMNI_TUNNEL_PROFILE=omni-commander
